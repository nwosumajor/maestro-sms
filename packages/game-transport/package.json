    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "echo \"(no lint configured)\""
  },
  "dependencies": {
    "@sms/game-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^20.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  }
}
