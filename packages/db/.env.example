# --- Prisma / DB ---
# App role (least privilege) — used by the running app and `prisma migrate`.
DATABASE_URL=postgresql://major_user:password@localhost:5432/sms?schema=public

# Privileged migration role — runs schema DDL + the RLS migration (Golden Rule #4).
DATABASE_MIGRATE_URL=postgresql://sms_migrator:password@localhost:5432/sms?schema=public

# Test DB for the RLS e2e suite (connect as the APP role so RLS is in force).
TEST_DATABASE_URL=postgresql://major_user:password@localhost:5432/sms_test?schema=public
