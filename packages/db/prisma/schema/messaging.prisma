// =============================================================================
// Messaging — two-way threaded messages (parent ↔ teacher ↔ staff)
// =============================================================================
// A thread has participants and an append-only message list. You only see and
// post to threads you participate in (enforced in MessagingService). Non-staff
// may only START a thread with staff/teachers — not other families. All
// tenant-scoped (non-null schoolId), RLS-enforced. New messages notify the other
// participants via the Notifications module.
// =============================================================================

model MessageThread {
  id       String @id @default(uuid()) @db.Uuid
  schoolId String @db.Uuid
  subject  String
  createdById String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School              @relation(fields: [schoolId], references: [id])
  participants ThreadParticipant[]
  messages     Message[]

  @@index([schoolId])
  @@map("message_thread")
}

model ThreadParticipant {
  id       String @id @default(uuid()) @db.Uuid
  schoolId String @db.Uuid
  threadId String @db.Uuid
  userId   String @db.Uuid
  /// For unread counts: messages after this timestamp are unread.
  lastReadAt DateTime?

  createdAt DateTime @default(now())

  school School        @relation(fields: [schoolId], references: [id])
  thread MessageThread @relation(fields: [threadId], references: [id])

  @@unique([threadId, userId])
  @@index([schoolId])
  @@index([schoolId, userId])
  @@map("thread_participant")
}

/// Append-only message within a thread.
model Message {
  id       String @id @default(uuid()) @db.Uuid
  schoolId String @db.Uuid
  threadId String @db.Uuid
  senderId String @db.Uuid
  body     String

  createdAt DateTime @default(now())

  school School        @relation(fields: [schoolId], references: [id])
  thread MessageThread @relation(fields: [threadId], references: [id])

  @@index([schoolId])
  @@index([schoolId, threadId])
  @@map("message")
}
