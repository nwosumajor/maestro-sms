// =============================================================================
// LMS core — Classes, Enrollment, Teaching assignments, Guardian links
// =============================================================================
// The keystone for relationship-scoping (RBAC beyond role, per CLAUDE.md):
//   - a teacher sees only THEIR classes      (ClassTeacher)
//   - a student sees only THEIR classes      (Enrollment)
//   - a parent sees only THEIR children      (ParentChild) and their classes
// All tenant-scoped (non-null schoolId, RLS-enforced). These are MEMBERSHIP
// tables; the relationship checks live in the service layer on top of RLS.
// =============================================================================

/// A class/section within a school (e.g. "History 101"). Assessments belong to
/// a class, which is how integrity reports become teacher-of-class scoped.
model Class {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @db.Uuid
  name         String
  subject      String?
  /// Ordering within the school's progression (e.g. JSS1=1, JSS2=2). Drives the
  /// "promote to the next class" flow together with nextClassId.
  level        Int?
  /// The class students promote INTO at end of session. Null = final/terminal
  /// class (promotion graduates instead of moving). Self-relation within a school.
  nextClassId  String?  @db.Uuid
  /// A staff member who supervises this class (form teacher). Gains roster READ
  /// access to the class even if not a subject teacher. Optional.
  supervisorId String?  @db.Uuid
  /// Max ACTIVE enrollments; enrollment/import/promotion refuse to exceed it. Null
  /// = unlimited.
  capacity     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school             School                @relation(fields: [schoolId], references: [id])
  teachers           ClassTeacher[]
  enrollments        Enrollment[]
  assessments        Assessment[]
  attendanceSessions AttendanceSession[]
  lmsContents        LmsContent[]
  subjectTeachers    ClassSubjectTeacher[]

  nextClass       Class?           @relation("ClassProgression", fields: [nextClassId], references: [id])
  previousClasses Class[]          @relation("ClassProgression")
  supervisor      User?            @relation("ClassSupervisor", fields: [supervisorId], references: [id])
  promotionsFrom  PromotionBatch[] @relation("PromotionSource")
  promotionsTo    PromotionBatch[] @relation("PromotionTarget")

  @@index([schoolId])
  @@index([schoolId, supervisorId])
  @@map("class")
}

enum PromotionStatus {
  PENDING
  APPROVED
  REJECTED
}

/// A staged end-of-session promotion of a class's students into its next class.
/// Maker-checker: an initiator stages the batch (nothing moves); school_admin
/// approves, which moves each student's enrollment (source -> PROMOTED, a new
/// ACTIVE enrollment in the target, or GRADUATED for a final class). initiated/
/// reviewed ids are audit-style scalars. Tenant-scoped.
model PromotionBatch {
  id            String          @id @default(uuid()) @db.Uuid
  schoolId      String          @db.Uuid
  sourceClassId String          @db.Uuid
  /// Null = final class: approving GRADUATES the students instead of moving them.
  targetClassId String?         @db.Uuid
  /// Student user ids included in this promotion (snapshot at stage time).
  studentIds    Json
  status        PromotionStatus @default(PENDING)
  /// The academic term this promotion runs at the end of (e.g. third term). Scalar
  /// ref to term(id); the DB FK is added in the migration. Optional.
  termId        String?         @db.Uuid
  initiatedById String          @db.Uuid
  reviewedById  String?         @db.Uuid
  reviewNote    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  school      School @relation(fields: [schoolId], references: [id])
  sourceClass Class  @relation("PromotionSource", fields: [sourceClassId], references: [id])
  targetClass Class? @relation("PromotionTarget", fields: [targetClassId], references: [id])

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("promotion_batch")
}

/// A subject in the school's catalog (e.g. "Mathematics"). Reusable across
/// classes; offered to a class via ClassSubjectTeacher. Tenant-scoped.
model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school        School                @relation(fields: [schoolId], references: [id])
  classSubjects ClassSubjectTeacher[]

  @@index([schoolId])
  @@map("subject")
}

/// A class's offering of a subject, taught by one assigned teacher. One teacher
/// per (class, subject). Tenant-scoped.
model ClassSubjectTeacher {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  classId         String   @db.Uuid
  subjectId       String   @db.Uuid
  teacherId       String   @db.Uuid
  /// CSP timetable-generation quota: lessons per week this offering receives.
  lessonsPerWeek  Int      @default(2)
  /// Fixed room this offering must be taught in (e.g. Chemistry -> Science Lab);
  /// the CSP solver treats it as a hard no-double-booking constraint. Scalar
  /// uuid with a DB-level FK to room (no Prisma relation — keeps models lean).
  preferredRoomId String?  @db.Uuid
  createdAt       DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher User    @relation("SubjectTeaching", fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@index([schoolId])
  @@index([schoolId, teacherId])
  @@map("class_subject_teacher")
}

/// Teaching assignment: which teachers teach a class. Drives "teacher sees only
/// their classes".
model ClassTeacher {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  classId   String   @db.Uuid
  teacherId String   @db.Uuid
  createdAt DateTime @default(now())

  school  School @relation(fields: [schoolId], references: [id])
  class   Class  @relation(fields: [classId], references: [id])
  teacher User   @relation("TeacherClasses", fields: [teacherId], references: [id])

  @@unique([classId, teacherId])
  @@index([schoolId])
  @@index([schoolId, teacherId])
  @@map("class_teacher")
}

/// Student enrollment in a class. Drives "student sees only their classes" and
/// (via ParentChild) "parent sees only their children's classes".
model Enrollment {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @db.Uuid
  classId      String   @db.Uuid
  studentId    String   @db.Uuid
  /// ACTIVE | PROMOTED | GRADUATED | TRANSFERRED | WITHDRAWN.
  status       String   @default("ACTIVE")
  /// Reason captured on a transfer/withdrawal (lifecycle audit context).
  statusReason String?
  enrolledAt   DateTime @default(now())

  school  School @relation(fields: [schoolId], references: [id])
  class   Class  @relation(fields: [classId], references: [id])
  student User   @relation("StudentEnrollments", fields: [studentId], references: [id])

  @@unique([classId, studentId])
  @@index([schoolId])
  @@index([schoolId, studentId])
  @@map("enrollment")
}

/// Guardian link: a parent/guardian to a student. Drives "parent sees only their
/// own children". // SECURITY: every parent-facing query joins through this.
model ParentChild {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @db.Uuid
  parentId     String   @db.Uuid
  studentId    String   @db.Uuid
  relationship String?
  createdAt    DateTime @default(now())

  school  School @relation(fields: [schoolId], references: [id])
  parent  User   @relation("ParentLinks", fields: [parentId], references: [id])
  student User   @relation("ChildLinks", fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@index([schoolId])
  @@index([schoolId, parentId])
  @@map("parent_child")
}
