// =============================================================================
// Dead & Wounded — Ultimate (cross-school) arena (platform spec §7/§10, step 8)
// =============================================================================
// THE ONE DELIBERATE EXCEPTION to tenant isolation. Built as a SEPARATE surface
// so it can never become a hole in the tenant wall. Two distinct groups of
// tables, kept explicitly apart:
//
//  (A) CROSS-TENANT ARENA — `ultimate_competition`, `ultimate_participant`.
//      RLS-EXEMPT BY DESIGN (a cross-school leaderboard must read across schools)
//      — listed in 21_ultimate_rls.sql alongside `school`/`role` as exempt. They
//      carry ONLY the minimum that may cross the boundary (spec §7/§10):
//        - an OPAQUE participant id (NOT a userId)
//        - the chosen HANDLE (never a real name)
//        - schoolId for grouping/leaderboard ONLY (scalar; no PII join)
//        - the secret (SERVER-ONLY, never serialized; per-entry, not shared)
//        - scores (guessCount / elapsedMs)
//      No userId, no student name, no class/school data beyond schoolId.
//
//  (B) TENANT-SCOPED BRIDGE & GOVERNANCE — `ultimate_entry_link`,
//      `ultimate_consent`, `ultimate_enrollment`. STANDARD RLS (school_id scoped).
//      `ultimate_entry_link` is the ONLY place a userId ↔ opaque participantId
//      mapping exists, so an arena row can only be de-anonymised WITHIN its own
//      school. Consent (per-student guardian flag) and enrollment (per-competition
//      school opt-in) are the two consent tiers from spec §7.
// =============================================================================

enum UltimateStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

enum UltimateParticipantStatus {
  ACTIVE
  FINISHED
}

/// (A) CROSS-TENANT, RLS-EXEMPT. Created/scheduled by super_admin only.
model UltimateCompetition {
  id               String         @id @default(uuid()) @db.Uuid
  name             String
  /// Fixed difficulty (4|5|6) — segmented events (spec §7).
  difficultyLength Int
  status           UltimateStatus @default(ACTIVE)
  startAt          DateTime
  endAt            DateTime
  /// super_admin userId (audit field; scalar — NO cross-tenant user relation).
  createdById      String         @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants UltimateParticipant[]

  @@map("ultimate_competition")
}

/// (A) CROSS-TENANT, RLS-EXEMPT. The cross-school leaderboard row. CARRIES NO PII.
model UltimateParticipant {
  /// Opaque player id — the public arena identity. NOT a userId. The userId
  /// mapping lives ONLY in the RLS-scoped `ultimate_entry_link`.
  id            String  @id @default(uuid()) @db.Uuid
  competitionId String  @db.Uuid
  /// Grouping/leaderboard only (spec §7 allows the school NAME across the wall).
  /// Scalar uuid + DB FK to school; NO Prisma relation (keeps the arena standalone).
  schoolId      String  @db.Uuid
  /// The student-chosen pseudonym (spec §7). NEVER a real name.
  handle        String
  /// SECURITY: per-entry target secret — SERVER-ONLY, never serialized, cleared
  /// on finish. Per-entry (not one shared secret) is the leak-resistant choice
  /// (spec §5 reasoning applied to a multi-day, cross-school, unmonitored event).
  secret        String?

  startedAt   DateTime                  @default(now())
  guessCount  Int                       @default(0)
  lastGuessAt DateTime?
  /// Elapsed ms from this player's OWN start (time-independent ranking, §7).
  elapsedMs   Int?
  finishedAt  DateTime?
  status      UltimateParticipantStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competition UltimateCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([competitionId, schoolId])
  @@map("ultimate_participant")
}

/// (B) TENANT-SCOPED, RLS. Tier-1: a school opts INTO a given competition.
model UltimateEnrollment {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @db.Uuid
  competitionId String   @db.Uuid
  enrolledById  String   @db.Uuid
  createdAt     DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, competitionId])
  @@index([schoolId])
  @@map("ultimate_enrollment")
}

/// (B) TENANT-SCOPED, RLS. Tier-2: per-student guardian/school consent to appear
/// on any cross-school surface (spec §7). Absent/false → the student cannot enter.
model UltimateConsent {
  id          String   @id @default(uuid()) @db.Uuid
  schoolId    String   @db.Uuid
  studentId   String   @db.Uuid
  granted     Boolean  @default(false)
  grantedById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId])
  @@index([schoolId])
  @@map("ultimate_consent")
}

/// (B) TENANT-SCOPED, RLS. The ONLY userId ↔ opaque participantId bridge. Lives
/// in the protected per-school space so an arena row is de-anonymisable ONLY
/// within its owning school. participantId/competitionId/userId are scalar (DB
/// FKs); no cross-tenant Prisma relations.
model UltimateEntryLink {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @db.Uuid
  competitionId String   @db.Uuid
  userId        String   @db.Uuid
  participantId String   @db.Uuid
  handle        String
  createdAt     DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  @@unique([competitionId, userId])
  @@index([schoolId])
  @@map("ultimate_entry_link")
}
