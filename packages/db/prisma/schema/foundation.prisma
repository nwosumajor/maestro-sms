// =============================================================================
// Foundation models — multi-tenancy, users, custom RBAC, audit, consent
// =============================================================================
// Replaces the earlier id-only stubs with the REAL foundation. Global (non-
// tenant) tables — School registry, Role/Permission/RolePermission — are
// RLS-EXEMPT and listed explicitly. Tenant-scoped tables (User, UserRole,
// AuditLog, IntegrityConsent) carry a non-null schoolId and are RLS-enforced
// (see prisma/migrations/<ts>_foundation_rls/migration.sql). Golden Rules #1–#5.
// =============================================================================

/// GLOBAL (RLS-exempt): the tenant registry.
model School {
  id                     String   @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String   @unique
  status                 String   @default("ACTIVE")
  /// TRUE only for the single platform-owner organization ("SMS Platform") that
  /// hosts super_admin(s). It is NOT a customer tenant: excluded from the public
  /// school directory, the operator tenant list, cross-school directory search and
  /// platform billing. Lets the super_admin be a platform identity (not a member
  /// of any customer school) while keeping user.schoolId non-null + RLS intact.
  isPlatform             Boolean  @default(false)
  /// Paystack SPLIT settlement for parent fee payments: when set, every fee
  /// charge carries this subaccount so the money settles to the SCHOOL's own
  /// bank (platform keeps only the configured commission %). Managed by the
  /// school's own finance staff via PUT /fees/settlement (step-up).
  paystackSubaccountCode String?
  settlementBankCode     String?
  settlementBankName     String?
  /// Display-only last 4 digits of the settlement account (full number is never
  /// stored — it lives with Paystack).
  settlementAccountLast4 String?
  /// Per-school override of who bears the platform's online-payment convenience
  /// fee: PARENT | SCHOOL; null → the platform-wide default. Set by the school's
  /// own finance staff (fee.manage + step-up, privileged write like settlement).
  paymentFeeBearer       String?
  /// Automatic late fee (kobo) added ONCE to an invoice still unpaid past
  /// dueDate + lateFeeGraceDays; 0 disables. Finance-staff-set (fee.manage +
  /// step-up, privileged write) like the other school fee columns.
  lateFeeFlatMinor       Int      @default(0)
  lateFeeGraceDays       Int      @default(7)
  /// Admission-form fee (kobo) charged to PUBLIC applicants before review;
  /// 0 = free applications. Set by finance staff (fee.manage + step-up,
  /// privileged write). Collected via the school's settlement split with the
  /// platform's take-rate applied — the same rails as fee collection.
  admissionFormFeeMinor  Int      @default(0)
  /// NDPR-aligned retention window (days) for integrity TELEMETRY on minors —
  /// integrity_signal / submission_draft / submission_telemetry. Read by the
  /// privileged retention job; rows older than this are purged. Per-school policy
  /// on the global registry (RLS-exempt). 0 disables purging for the school.
  integrityRetentionDays Int      @default(365)
  /// Proprietor/owner contact — the business relationship the platform bills.
  /// Captured at onboarding (public form requires it; provisioning stamps it,
  /// falling back to the linked request), shown in the operator directory.
  /// Global-registry columns: app role SELECT-only, writes via the privileged
  /// client (provisioning / operator console) like every other school column.
  ownerName              String?
  ownerPhone             String?
  /// Physical school address (from the onboarding request; operator-visible).
  address                String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // foundation relations
  users             User[]
  userRoles         UserRole[]
  auditLogs         AuditLog[]
  integrityConsents IntegrityConsent[]

  // LMS relations
  classes              Class[]
  classTeachers        ClassTeacher[]
  enrollments          Enrollment[]
  parentChildren       ParentChild[]
  subjects             Subject[]
  classSubjectTeachers ClassSubjectTeacher[]
  promotionBatches     PromotionBatch[]
  academicSessions     AcademicSession[]
  terms                Term[]
  announcements        Announcement[]

  // Gradebook
  grades                  Grade[]
  reportCardRemarks       ReportCardRemark[]
  subjectResults          SubjectResult[]
  subjectSelections       SubjectSelection[]
  scholarshipApplications ScholarshipApplication[]

  // Approval workflow
  workflowRequests  WorkflowRequest[]
  workflowAuditLogs WorkflowAuditLog[]

  // integrity-module relations
  assessments                Assessment[]
  submissions                Submission[]
  submissionDrafts           SubmissionDraft[]
  integritySignals           IntegritySignal[]
  submissionTelemetry        SubmissionTelemetry[]
  studentIntegrityExemptions StudentIntegrityExemption[]
  integrityRetentionRuns     IntegrityRetentionRun[]

  // SIS relations
  studentProfiles      StudentProfile[]
  emergencyContacts    EmergencyContact[]
  medicalRecords       MedicalRecord[]
  studentImportBatches StudentImportBatch[]
  parentImportBatches  ParentImportBatch[]

  // Attendance relations
  attendanceSessions AttendanceSession[]
  attendanceRecords  AttendanceRecord[]

  // Notifications relations
  notifications          Notification[]
  notificationDeliveries NotificationDelivery[]
  notificationPreferences NotificationPreference[]

  // Fees / Billing relations
  feeItems             FeeItem[]
  invoices             Invoice[]
  invoiceLineItems     InvoiceLineItem[]
  payments             Payment[]
  paymentDisputes      PaymentDispute[]
  virtualAccounts      StudentVirtualAccount[]
  invoiceInstallments  InvoiceInstallment[]
  studentCreditEntries StudentCreditEntry[]
  invoiceAdjustments   InvoiceAdjustment[]

  // Document Vault relations
  documents Document[]

  // Timetabling relations
  periods                 Period[]
  rooms                   Room[]
  timetableEntries        TimetableEntry[]
  teacherUnavailabilities TeacherUnavailability[]
  lessonCovers            LessonCover[]

  // Security relations
  privilegeGrants PrivilegeGrant[]

  // Privacy relations
  erasureRequests ErasureRequest[]

  // Messaging + Calendar relations
  messageThreads     MessageThread[]
  threadParticipants ThreadParticipant[]
  messages           Message[]
  schoolEvents       SchoolEvent[]

  // HR
  employees Employee[]

  // Admissions
  admissionApplications AdmissionApplication[]

  // Dead & Wounded game
  games                Game[]
  gamePlayers          GamePlayer[]
  guesses              Guess[]
  gameResults          GameResult[]
  competitions         Competition[]
  standings            Standing[]
  gameSettings         GameSettings[]
  // Live Quiz (Kahoot-style, curriculum-themed)
  liveQuizzes          LiveQuiz[]
  liveQuizQuestions    LiveQuizQuestion[]
  liveQuizSessions     LiveQuizSession[]
  liveQuizParticipants LiveQuizParticipant[]
  liveQuizAnswers      LiveQuizAnswer[]
  // Hangman (classroom letter-guessing)
  hangmanGames         HangmanGame[]
  hangmanPlayers       HangmanPlayer[]
  // Typing Race
  typingRaces          TypingRace[]
  typingRacers         TypingRacer[]
  // Checkers
  checkersGames        CheckersGame[]
  // Chess
  chessGames           ChessGame[]
  // Ultimate (cross-school) — ONLY the tenant-scoped governance/bridge tables
  // relate back to School; the cross-tenant arena tables deliberately do not.
  ultimateEnrollments  UltimateEnrollment[]
  ultimateConsents     UltimateConsent[]
  ultimateEntryLinks   UltimateEntryLink[]

  // Subscription / module entitlement (one row per school)
  subscription         SchoolSubscription?
  // Platform billing — append-only payment ledger (school -> platform)
  platformPayments     PlatformSubscriptionPayment[]
  // Referral program (this school as the REFERRER)
  referralCode         SchoolReferralCode?
  referralConversions  SchoolReferralConversion[]
  // Message-credit ledger (SMS/WhatsApp bundles)
  messageCreditEntries MessageCreditEntry[]
  // CBT exam hall
  cbtQuestionBanks     CbtQuestionBank[]
  cbtQuestions         CbtQuestion[]
  cbtExams             CbtExam[]
  cbtSittings          CbtSitting[]
  // Legal clickwrap ledger
  legalAcceptances     LegalAcceptance[]

  // LMS learning content
  lmsContents  LmsContent[]
  quizAttempts QuizAttempt[]
  forumPosts   ForumPost[]

  @@map("school")
}

/// TENANT-SCOPED: a school's subscription plan + per-school module overrides.
/// The platform (super_admin) sets this; the ModuleGuard reads it to gate routes
/// and the web nav hides disabled modules. RLS scopes a school to its OWN row;
/// super_admin writes via a per-school GUC (like the rest of the operator console).
/// A school with NO row falls back to DEFAULT_PLAN (the STANDARD floor — fail-closed).
model SchoolSubscription {
  id                       String    @id @default(uuid()) @db.Uuid
  schoolId                 String    @unique @db.Uuid
  /// STANDARD | PREMIUM | ULTIMATE | ENTERPRISE (validated against @sms/types PLANS).
  /// This is the PURCHASED tier; delinquency NEVER overwrites it — the effective
  /// plan is computed (effectivePlan) from `status` + `currentPeriodEnd` instead.
  /// FAIL-CLOSED default: a row created without an explicit plan gets the entry
  /// tier, mirroring DEFAULT_PLAN in @sms/types — a data gap under-provisions,
  /// never silently hands out the premium suite. Every real path (onboarding,
  /// billing, operator, seed) sets the plan explicitly anyway.
  plan                     String    @default("STANDARD")
  /// { enabled?: string[]; disabled?: string[] } — per-school deviations.
  overrides                Json      @default("{}")
  /// ACTIVE | PAST_DUE | CANCELED (validated against @sms/types SUBSCRIPTION_STATUS).
  status                   String    @default("ACTIVE")
  /// Per-school grace window (days past `currentPeriodEnd` before the effective
  /// plan drops to the STANDARD floor). NULL → platform default
  /// (SUBSCRIPTION_GRACE_DAYS). Bounded 0–GRACE_DAYS_MAX at the API — a bounded
  /// customer-service lever (delegable), never an unbounded comp (owner-only).
  graceDays                Int?
  /// MONTH | TERM | YEAR.
  billingCycle             String    @default("TERM")
  /// End of the currently-paid period; null for never-paid (default/comp).
  currentPeriodEnd         DateTime?
  /// Seat count (active students) last billed.
  seats                    Int?
  /// Currency of the last charge (NGN | USD); null when never paid.
  currency                 String?
  /// Amount last charged (minor units, NGN kobo).
  priceMinor               Int?
  /// Paystack customer code (captured with the saved card).
  paystackCustomerCode     String?
  /// Saved-card recurring: the reusable Paystack authorization_code, field-
  /// encrypted at rest (per-tenant key) — captured from the school's own
  /// successful subscription charge, never entered by hand. cardLast4 is the
  /// display hint. autoRenew arms the pre-dunning renewal charge.
  paystackAuthorizationEnc String?
  cardLast4                String?
  autoRenew                Boolean   @default(false)
  /// Set at provisioning when this school arrived via a referral code — the
  /// school that referred them. The billing webhook grants BOTH sides one free
  /// term on this school's FIRST paid subscription, then stamps
  /// referralRewardAt so a retry / later renewal can never double-grant.
  referredBySchoolId       String?   @db.Uuid
  referralRewardAt         DateTime?
  /// Agent (reseller) attribution: set at provisioning from the agent's code;
  /// commission accrues once, on this school's FIRST paid subscription.
  agentId                  String?   @db.Uuid
  /// Metered UNBILLED seat usage (kobo/cents in `currency`): the daily sweep
  /// accrues seat-days for students above the billed `seats` count; settled
  /// (and zeroed by the paid amount) via top-up or the next renewal charge.
  seatArrearsMinor         Int       @default(0)
  /// Last accrual stamp — the elapsed window the next accrual covers.
  arrearsAccruedAt         DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@map("school_subscription")
}

/// GLOBAL (RLS-EXEMPT, like `school`/`role`): operator-set per-tier pricing.
/// One optional row per plan tier overrides the platform default in
/// @sms/types PLAN_PRICING; absent rows fall back to the constant. Read by every
/// tenant (quotes/checkout/public pricing page) — carries NO tenant data.
/// Writes go ONLY through the PRIVILEGED client (operator PUT, step-up, audited);
/// the least-privilege app role has SELECT only (see rls/46_plan_pricing_rls.sql).
/// APPEND-ONLY clickwrap ledger: who accepted which VERSION of the platform
/// legal pack (MSA/DPA/Privacy/Refunds/Cyber — LEGAL_DOCS_VERSION in
/// @sms/types), when, and in what context (ONBOARDING | IN_APP). Tenant-scoped
/// (rls/76, SELECT+INSERT only — an acceptance is evidence, never edited).
/// Public-form acceptances (no tenant yet) live on onboarding_request instead.
model LegalAcceptance {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @db.Uuid
  userId     String   @db.Uuid
  docVersion String
  context    String
  acceptedAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, docVersion])
  @@map("legal_acceptance")
}

/// GLOBAL (RLS-EXEMPT, like `plan_price`): the platform's convenience fee on
/// ONLINE school-fee payments — one row (id "fees"). App role SELECT-only;
/// writes via the PRIVILEGED client (operator PUT, step-up, audited). Missing
/// row ⇒ DEFAULT_PLATFORM_FEE in @sms/types (ZERO — fail-safe: nobody is
/// charged until the operator opts in). See rls/71_platform_fee_rls.sql.
model PlatformFeeConfig {
  id        String   @id
  /// Flat component, minor units (kobo).
  flatMinor Int      @default(0)
  /// Percentage component in basis points (100 bp = 1%).
  percentBp Int      @default(0)
  /// Ceiling on the total fee, minor units; null = uncapped.
  capMinor  Int?
  /// Platform-wide default bearer: PARENT | SCHOOL (school may override its own
  /// via school.paymentFeeBearer).
  bearer    String   @default("PARENT")
  updatedAt DateTime @updatedAt

  @@map("platform_fee_config")
}

model PlanPrice {
  /// STANDARD | PREMIUM | ULTIMATE | ENTERPRISE (validated against @sms/types PLANS).
  plan                String
  /// NGN | USD — one override row per (tier, currency). ENTERPRISE is USD-only
  /// (enforced in PlanPricingService.update, not the schema).
  currency            String   @default("NGN")
  /// Per-seat (active student) monthly price, minor units (kobo / cents).
  perSeatMonthlyMinor Int
  updatedAt           DateTime @updatedAt

  @@id([plan, currency])
  @@map("plan_price")
}

/// Append-only ledger of a school's PLATFORM subscription payments (school ->
/// platform — orthogonal to parent->school Fees). Tenant-scoped (non-null
/// schoolId + RLS); no hard-delete (financial record). A PENDING row is created
/// at checkout and flipped to PAID by the verified Paystack webhook.
model PlatformSubscriptionPayment {
  id            String    @id @default(uuid()) @db.Uuid
  schoolId      String    @db.Uuid
  /// Tier being purchased.
  plan          String
  /// MONTH | TERM | YEAR.
  billingCycle  String
  /// Seat count snapshot the price was computed from.
  seats         Int
  /// Charge amount (minor units of `currency`: NGN kobo / USD cents).
  amountMinor   Int
  /// NGN (Paystack) | USD (Stripe).
  currency      String    @default("NGN")
  /// Idempotency + gateway transaction reference (Paystack ref / Stripe session).
  reference     String    @unique
  /// PENDING | PAID | FAILED.
  status        String    @default("PENDING")
  /// How this payment applies when it settles (SUBSCRIPTION_PAYMENT_KINDS):
  /// RENEWAL extends the period; UPGRADE restarts it from now (unused time was
  /// credited at checkout); TRUEUP updates the billed seats only.
  kind          String    @default("RENEWAL")
  /// Promo code snapshot when one discounted this charge (settle-time increments
  /// the code's usedCount).
  promoCode     String?
  /// Seat-arrears portion INCLUDED in amountMinor (settle decrements the
  /// subscription's seatArrearsMinor by exactly this — never a blind zeroing).
  arrearsMinor  Int       @default(0)
  /// Period this payment covers (set when PAID).
  periodStart   DateTime?
  periodEnd     DateTime?
  paidAt        DateTime?
  /// The staff member who initiated the checkout.
  initiatedById String    @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("platform_subscription_payment")
}

/// TENANT-SCOPED: a person in a school. Email is globally unique so login is
/// unambiguous. passwordHash is bcrypt; the app NEVER stores plaintext.
model User {
  id                String    @id @default(uuid()) @db.Uuid
  schoolId          String    @db.Uuid
  email             String    @unique
  name              String
  passwordHash      String
  /// Mobile number for SMS/WhatsApp notification delivery (self-service on
  /// /account; loose E.164). Absent → those channels fail soft ("no target").
  phone             String?
  status            String    @default("ACTIVE")
  /// Human-readable GLOBAL unique identifier for every person (student + staff) —
  /// for ID cards, audit, and cross-school search. Auto-generated by a DB default
  /// on every insert (so ALL creation paths get one with no app code), globally
  /// unique. Format: SMS-XXXXXXXXXXXX.
  uniqueId          String    @unique @default(dbgenerated("('SMS-' || upper(substr(md5((random())::text || (clock_timestamp())::text), 1, 12)))"))
  /// TOTP MFA: base32 secret (null until enrolled) + whether it's confirmed/on.
  mfaSecret         String?
  mfaEnabled        Boolean   @default(false)
  /// Platform-owner mandate: when true, login is blocked until the user enrols
  /// MFA (mfaEnabled). Set by super_admin per-user or per-role from the operator
  /// console. Distinct from mfaEnabled (the user's own enrolment state).
  mfaRequired       Boolean   @default(false)
  /// Brute-force protection: consecutive failed logins. On the 3rd miss the account
  /// is LOCKED (permanent — cleared only by a super_admin). lockedUntil records when.
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  /// True once locked out; only a super_admin (operator console) can reactivate.
  locked            Boolean   @default(false)
  /// When the password was last set. Non-super_admin accounts must reset every 30
  /// days (enforced at login). Defaults to now() so new/existing accounts get a
  /// fresh window; set to null by an admin password reset to force an immediate change.
  passwordChangedAt DateTime? @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  school School     @relation(fields: [schoolId], references: [id])
  roles  UserRole[]

  // integrity-module relations
  createdAssessments           Assessment[]                @relation("AssessmentCreatedBy")
  submissions                  Submission[]                @relation("SubmissionStudent")
  integrityExemptionsAsStudent StudentIntegrityExemption[] @relation("ExemptionStudent")
  integrityExemptionsGranted   StudentIntegrityExemption[] @relation("ExemptionGrantedBy")
  integrityExemptionsRevoked   StudentIntegrityExemption[] @relation("ExemptionRevokedBy")

  // audit + consent relations
  auditLogs         AuditLog[]         @relation("AuditActor")
  consentsAsStudent IntegrityConsent[] @relation("ConsentStudent")
  consentsGranted   IntegrityConsent[] @relation("ConsentGrantedBy")
  consentsRevoked   IntegrityConsent[] @relation("ConsentRevokedBy")

  // LMS relations
  teacherClasses     ClassTeacher[]        @relation("TeacherClasses")
  studentEnrollments Enrollment[]          @relation("StudentEnrollments")
  parentLinks        ParentChild[]         @relation("ParentLinks")
  childLinks         ParentChild[]         @relation("ChildLinks")
  supervisedClasses  Class[]               @relation("ClassSupervisor")
  subjectTeaching    ClassSubjectTeacher[] @relation("SubjectTeaching")

  // LMS learning content
  authoredContent LmsContent[]  @relation("ContentAuthor")
  quizAttempts    QuizAttempt[] @relation("StudentQuizAttempts")
  forumPosts      ForumPost[]   @relation("ForumAuthor")

  // Gradebook
  gradesGiven Grade[] @relation("GradesGiven")

  // Approval workflow
  initiatedWorkflows WorkflowRequest[] @relation("InitiatedWorkflows")

  // SIS
  studentProfile StudentProfile? @relation("StudentProfileUser")

  // Attendance
  attendanceTaken   AttendanceSession[] @relation("AttendanceTakenBy")
  attendanceRecords AttendanceRecord[]  @relation("AttendanceStudent")

  // Notifications
  notifications Notification[] @relation("NotificationRecipient")

  @@index([schoolId])
  @@map("user")
}

/// GLOBAL (RLS-exempt): system roles (super_admin, school_admin, teacher,
/// student, parent, finance). All but super_admin are scoped to a school via
/// the UserRole assignment, not the role itself.
model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("role")
}

/// GLOBAL (RLS-exempt): fine-grained permission strings (e.g. "grade.write").
model Permission {
  id  String @id @default(uuid()) @db.Uuid
  key String @unique

  roles RolePermission[]

  @@map("permission")
}

/// GLOBAL (RLS-exempt): role -> permission mapping.
model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permission")
}

/// TENANT-SCOPED: a user's role assignment within their school.
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([schoolId])
  @@map("user_role")
}

/// TENANT-SCOPED, APPEND-ONLY: the durable audit trail (Golden Rule #5). The RLS
/// migration grants INSERT/SELECT only — never UPDATE/DELETE — so entries are
/// tamper-evident. Every mutation across the app writes one of these.
/// APPEND-ONLY. RANGE-PARTITIONED by month on `createdAt` (migration
/// 20260824000000_audit_log_partition) — the highest-write table, and it grows
/// forever. Postgres requires the partition key in every PK, hence the COMPOSITE
/// id: safe because this table is only ever findMany/create — never findUnique,
/// update or delete by id (RLS grants INSERT/SELECT only). Partition maintenance
/// (rolling the window forward) is AuditPartitionService.
model AuditLog {
  id        String   @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  actorId   String   @db.Uuid
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@id([id, createdAt])
  @@index([schoolId])
  @@index([schoolId, entity, entityId])
  @@index([schoolId, createdAt])
  @@map("audit_log")
}

/// TENANT-SCOPED: NDPR consent for integrity telemetry on a minor (Golden Rule
/// #5). Active when revokedAt IS NULL. Granting/revoking is audit-logged.
model IntegrityConsent {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String    @db.Uuid
  studentId   String    @db.Uuid
  grantedById String    @db.Uuid
  grantedAt   DateTime  @default(now())
  revokedAt   DateTime?
  revokedById String?   @db.Uuid

  school    School @relation(fields: [schoolId], references: [id])
  student   User   @relation("ConsentStudent", fields: [studentId], references: [id])
  grantedBy User   @relation("ConsentGrantedBy", fields: [grantedById], references: [id])
  revokedBy User?  @relation("ConsentRevokedBy", fields: [revokedById], references: [id])

  @@index([schoolId, studentId])
  @@map("integrity_consent")
}

/// TENANT-SCOPED per-school branding (login-page logo). schoolId is a scalar FK
/// (no relation) like the game tables. Logo BYTES live in object storage; only
/// the key is stored here. The public login page reads it (via the branding
/// endpoint, which sets the tenant GUC after resolving the school by slug).
model SchoolBranding {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @unique @db.Uuid
  /// Object-storage key for the uploaded logo (null = none).
  logoKey    String?
  /// Per-school theme: brand colour as HSL (hue 0–360, sat/light 0–100) + an
  /// optional font-family stack. Null = inherit the platform default tokens.
  brandHue   Int?
  brandSat   Int?
  brandLight Int?
  fontFamily String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId])
  @@map("school_branding")
}
