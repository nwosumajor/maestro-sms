// =============================================================================
// Foundation models — multi-tenancy, users, custom RBAC, audit, consent
// =============================================================================
// Replaces the earlier id-only stubs with the REAL foundation. Global (non-
// tenant) tables — School registry, Role/Permission/RolePermission — are
// RLS-EXEMPT and listed explicitly. Tenant-scoped tables (User, UserRole,
// AuditLog, IntegrityConsent) carry a non-null schoolId and are RLS-enforced
// (see prisma/migrations/<ts>_foundation_rls/migration.sql). Golden Rules #1–#5.
// =============================================================================

/// GLOBAL (RLS-exempt): the tenant registry.
model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  /// NDPR-aligned retention window (days) for integrity TELEMETRY on minors —
  /// integrity_signal / submission_draft / submission_telemetry. Read by the
  /// privileged retention job; rows older than this are purged. Per-school policy
  /// on the global registry (RLS-exempt). 0 disables purging for the school.
  integrityRetentionDays Int @default(365)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // foundation relations
  users             User[]
  userRoles         UserRole[]
  auditLogs         AuditLog[]
  integrityConsents IntegrityConsent[]

  // LMS relations
  classes        Class[]
  classTeachers  ClassTeacher[]
  enrollments    Enrollment[]
  parentChildren ParentChild[]

  // Gradebook
  grades         Grade[]

  // Approval workflow
  workflowRequests  WorkflowRequest[]
  workflowAuditLogs WorkflowAuditLog[]

  // integrity-module relations
  assessments                Assessment[]
  submissions                Submission[]
  submissionDrafts           SubmissionDraft[]
  integritySignals           IntegritySignal[]
  submissionTelemetry        SubmissionTelemetry[]
  studentIntegrityExemptions StudentIntegrityExemption[]
  integrityRetentionRuns     IntegrityRetentionRun[]

  // SIS relations
  studentProfiles   StudentProfile[]
  emergencyContacts EmergencyContact[]
  medicalRecords    MedicalRecord[]

  // Attendance relations
  attendanceSessions AttendanceSession[]
  attendanceRecords  AttendanceRecord[]

  // Notifications relations
  notifications        Notification[]
  notificationDeliveries NotificationDelivery[]

  // Fees / Billing relations
  feeItems         FeeItem[]
  invoices         Invoice[]
  invoiceLineItems InvoiceLineItem[]
  payments         Payment[]

  // Document Vault relations
  documents Document[]

  // Timetabling relations
  periods         Period[]
  rooms           Room[]
  timetableEntries TimetableEntry[]

  // Security relations
  privilegeGrants PrivilegeGrant[]

  // Privacy relations
  erasureRequests ErasureRequest[]

  // Messaging + Calendar relations
  messageThreads     MessageThread[]
  threadParticipants ThreadParticipant[]
  messages           Message[]
  schoolEvents       SchoolEvent[]

  // HR
  employees Employee[]

  // Admissions
  admissionApplications AdmissionApplication[]

  // Dead & Wounded game
  games        Game[]
  gamePlayers  GamePlayer[]
  guesses      Guess[]
  gameResults  GameResult[]
  competitions Competition[]
  standings    Standing[]
  gameSettings GameSettings[]
  // Ultimate (cross-school) — ONLY the tenant-scoped governance/bridge tables
  // relate back to School; the cross-tenant arena tables deliberately do not.
  ultimateEnrollments UltimateEnrollment[]
  ultimateConsents    UltimateConsent[]
  ultimateEntryLinks  UltimateEntryLink[]

  // Subscription / module entitlement (one row per school)
  subscription SchoolSubscription?
  // Platform billing — append-only payment ledger (school -> platform)
  platformPayments PlatformSubscriptionPayment[]

  // LMS learning content
  lmsContents  LmsContent[]
  quizAttempts QuizAttempt[]
  forumPosts   ForumPost[]

  @@map("school")
}

/// TENANT-SCOPED: a school's subscription plan + per-school module overrides.
/// The platform (super_admin) sets this; the ModuleGuard reads it to gate routes
/// and the web nav hides disabled modules. RLS scopes a school to its OWN row;
/// super_admin writes via a per-school GUC (like the rest of the operator console).
/// A school with no row defaults to ENTERPRISE (everything on) — see DEFAULT_PLAN.
model SchoolSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @unique @db.Uuid
  /// BASIC | STANDARD | ENTERPRISE (validated in app against @sms/types PLANS).
  /// This is the PURCHASED tier; delinquency NEVER overwrites it — the effective
  /// plan is computed (effectivePlan) from `status` + `currentPeriodEnd` instead.
  plan      String   @default("ENTERPRISE")
  /// { enabled?: string[]; disabled?: string[] } — per-school deviations.
  overrides Json     @default("{}")
  /// ACTIVE | PAST_DUE | CANCELED (validated against @sms/types SUBSCRIPTION_STATUS).
  status            String    @default("ACTIVE")
  /// MONTH | TERM | YEAR.
  billingCycle      String    @default("TERM")
  /// End of the currently-paid period; null for never-paid (default/comp).
  currentPeriodEnd  DateTime?
  /// Seat count (active students) last billed.
  seats             Int?
  /// Amount last charged (minor units, NGN kobo).
  priceMinor        Int?
  /// Paystack customer code (reserved for future saved-card recurring).
  paystackCustomerCode String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@map("school_subscription")
}

/// Append-only ledger of a school's PLATFORM subscription payments (school ->
/// platform — orthogonal to parent->school Fees). Tenant-scoped (non-null
/// schoolId + RLS); no hard-delete (financial record). A PENDING row is created
/// at checkout and flipped to PAID by the verified Paystack webhook.
model PlatformSubscriptionPayment {
  id            String    @id @default(uuid()) @db.Uuid
  schoolId      String    @db.Uuid
  /// Tier being purchased.
  plan          String
  /// MONTH | TERM | YEAR.
  billingCycle  String
  /// Seat count snapshot the price was computed from.
  seats         Int
  /// Charge amount (minor units, NGN kobo).
  amountMinor   Int
  /// Idempotency + Paystack transaction reference.
  reference     String    @unique
  /// PENDING | PAID | FAILED.
  status        String    @default("PENDING")
  /// Period this payment covers (set when PAID).
  periodStart   DateTime?
  periodEnd     DateTime?
  paidAt        DateTime?
  /// The staff member who initiated the checkout.
  initiatedById String    @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("platform_subscription_payment")
}

/// TENANT-SCOPED: a person in a school. Email is globally unique so login is
/// unambiguous. passwordHash is bcrypt; the app NEVER stores plaintext.
model User {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  status       String   @default("ACTIVE")
  /// TOTP MFA: base32 secret (null until enrolled) + whether it's confirmed/on.
  mfaSecret    String?
  mfaEnabled   Boolean  @default(false)
  /// Platform-owner mandate: when true, login is blocked until the user enrols
  /// MFA (mfaEnabled). Set by super_admin per-user or per-role from the operator
  /// console. Distinct from mfaEnabled (the user's own enrolment state).
  mfaRequired  Boolean  @default(false)
  /// Brute-force protection: consecutive failed logins + a lockout deadline.
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school School     @relation(fields: [schoolId], references: [id])
  roles  UserRole[]

  // integrity-module relations
  createdAssessments           Assessment[]                @relation("AssessmentCreatedBy")
  submissions                  Submission[]                @relation("SubmissionStudent")
  integrityExemptionsAsStudent StudentIntegrityExemption[] @relation("ExemptionStudent")
  integrityExemptionsGranted   StudentIntegrityExemption[] @relation("ExemptionGrantedBy")
  integrityExemptionsRevoked   StudentIntegrityExemption[] @relation("ExemptionRevokedBy")

  // audit + consent relations
  auditLogs         AuditLog[]         @relation("AuditActor")
  consentsAsStudent IntegrityConsent[] @relation("ConsentStudent")
  consentsGranted   IntegrityConsent[] @relation("ConsentGrantedBy")
  consentsRevoked   IntegrityConsent[] @relation("ConsentRevokedBy")

  // LMS relations
  teacherClasses    ClassTeacher[] @relation("TeacherClasses")
  studentEnrollments Enrollment[]  @relation("StudentEnrollments")
  parentLinks       ParentChild[]  @relation("ParentLinks")
  childLinks        ParentChild[]  @relation("ChildLinks")

  // LMS learning content
  authoredContent   LmsContent[]  @relation("ContentAuthor")
  quizAttempts      QuizAttempt[] @relation("StudentQuizAttempts")
  forumPosts        ForumPost[]   @relation("ForumAuthor")

  // Gradebook
  gradesGiven       Grade[]        @relation("GradesGiven")

  // Approval workflow
  initiatedWorkflows WorkflowRequest[] @relation("InitiatedWorkflows")

  // SIS
  studentProfile StudentProfile? @relation("StudentProfileUser")

  // Attendance
  attendanceTaken   AttendanceSession[] @relation("AttendanceTakenBy")
  attendanceRecords AttendanceRecord[]  @relation("AttendanceStudent")

  // Notifications
  notifications Notification[] @relation("NotificationRecipient")

  @@index([schoolId])
  @@map("user")
}

/// GLOBAL (RLS-exempt): system roles (super_admin, school_admin, teacher,
/// student, parent, finance). All but super_admin are scoped to a school via
/// the UserRole assignment, not the role itself.
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("role")
}

/// GLOBAL (RLS-exempt): fine-grained permission strings (e.g. "grade.write").
model Permission {
  id  String @id @default(uuid()) @db.Uuid
  key String @unique

  roles RolePermission[]

  @@map("permission")
}

/// GLOBAL (RLS-exempt): role -> permission mapping.
model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permission")
}

/// TENANT-SCOPED: a user's role assignment within their school.
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([schoolId])
  @@map("user_role")
}

/// TENANT-SCOPED, APPEND-ONLY: the durable audit trail (Golden Rule #5). The RLS
/// migration grants INSERT/SELECT only — never UPDATE/DELETE — so entries are
/// tamper-evident. Every mutation across the app writes one of these.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  actorId   String   @db.Uuid
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([schoolId])
  @@index([schoolId, entity, entityId])
  @@index([schoolId, createdAt])
  @@map("audit_log")
}

/// TENANT-SCOPED: NDPR consent for integrity telemetry on a minor (Golden Rule
/// #5). Active when revokedAt IS NULL. Granting/revoking is audit-logged.
model IntegrityConsent {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String    @db.Uuid
  studentId   String    @db.Uuid
  grantedById String    @db.Uuid
  grantedAt   DateTime  @default(now())
  revokedAt   DateTime?
  revokedById String?   @db.Uuid

  school    School @relation(fields: [schoolId], references: [id])
  student   User   @relation("ConsentStudent", fields: [studentId], references: [id])
  grantedBy User   @relation("ConsentGrantedBy", fields: [grantedById], references: [id])
  revokedBy User?  @relation("ConsentRevokedBy", fields: [revokedById], references: [id])

  @@index([schoolId, studentId])
  @@map("integrity_consent")
}

/// TENANT-SCOPED per-school branding (login-page logo). schoolId is a scalar FK
/// (no relation) like the game tables. Logo BYTES live in object storage; only
/// the key is stored here. The public login page reads it (via the branding
/// endpoint, which sets the tenant GUC after resolving the school by slug).
model SchoolBranding {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @unique @db.Uuid
  /// Object-storage key for the uploaded logo (null = none).
  logoKey   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@map("school_branding")
}
