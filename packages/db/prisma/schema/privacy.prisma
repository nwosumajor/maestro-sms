// =============================================================================
// Privacy / NDPR data-subject rights — right-to-erasure requests
// =============================================================================
// Data SUBJECTS (students) and their guardians can request export of, and
// erasure of, a student's personal data. Export is served directly (a JSON
// bundle, audit-logged). Erasure is a governed REQUEST: a data controller
// (school_admin / principal) reviews it against retention obligations before any
// data is removed — erasing a minor's record is never a one-click action. All
// tenant-scoped (non-null schoolId), RLS-enforced.
// =============================================================================

enum ErasureStatus {
  PENDING
  APPROVED
  REJECTED
}

model ErasureRequest {
  id       String @id @default(uuid()) @db.Uuid
  schoolId String @db.Uuid

  /// The student whose data is requested for erasure (DB FK to user; scalar).
  studentId     String        @db.Uuid
  /// Who raised it (the subject or a guardian; DB FK to user; scalar).
  requestedById String        @db.Uuid
  reason        String
  status        ErasureStatus @default(PENDING)
  /// The controller who reviewed it (DB FK to user; scalar).
  reviewedById  String?       @db.Uuid
  reviewNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("erasure_request")
}
