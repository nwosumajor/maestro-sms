# Resilient install settings for flaky / proxied networks.
# Serializing fetches (concurrency=1) avoids the ECONNRESET storms that happen
# when many parallel requests hit a rate-limited or unstable connection.
network-concurrency=1
child-concurrency=1

# Be patient and retry hard before giving up.
fetch-retries=6
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-timeout=600000

# Reuse anything already in the store/cache.
prefer-offline=true

# If you are behind a corporate proxy or internal mirror, set these instead:
# registry=https://your-internal-registry/
# https-proxy=http://proxy:port
# proxy=http://proxy:port
