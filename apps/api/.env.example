# --- API ---
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development

# Shared secret used to VERIFY the Auth.js-issued JWT (must match the web app).
AUTH_SECRET=dev-only-change-me

# App DB role (least privilege; cannot DROP/ALTER/TRUNCATE).
DATABASE_URL=postgresql://major_user:password@localhost:5432/sms?schema=public

# Redis for BullMQ.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Local-dev consent default for the placeholder ConsentService (set false to test
# the deny path). Ignored/forced-closed in production.
INTEGRITY_CONSENT_DEFAULT=true
