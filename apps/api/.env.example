# --- API ---
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development

# Shared secret used to VERIFY the Auth.js-issued JWT (must match the web app).
AUTH_SECRET=dev-only-change-me

# App DB role (least privilege; cannot DROP/ALTER/TRUNCATE). In production point
# this at the connection pooler (RDS Proxy / PgBouncer, transaction mode) — the
# tenant GUC uses set_config(..., true) (transaction-local), so pooling is safe.
DATABASE_URL=postgresql://major_user:password@localhost:5432/sms?schema=public

# OPTIONAL read-replica endpoint. When set, read-only aggregate/report endpoints
# (runAsTenantReadOnly) route here to offload the primary writer at scale. Leave
# UNSET to run single-DB — reads then use DATABASE_URL, identical behaviour.
# DATABASE_REPLICA_URL=postgresql://major_user:password@replica-host:5432/sms?schema=public

# Redis for BullMQ.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Local-dev consent default for the placeholder ConsentService (set false to test
# the deny path). Ignored/forced-closed in production.
INTEGRITY_CONSENT_DEFAULT=true

# Outbound email (notification EMAIL channel + direct onboarding emails).
# Unset EMAIL_API_KEY => email disabled (logged only, never a crash).
# EMAIL_PROVIDER: resend (default) | postmark
#EMAIL_PROVIDER=resend
#EMAIL_API_KEY=
#EMAIL_FROM=SMS Platform <no-reply@yourdomain>
