# --- Web (Next.js + Auth.js) ---
# Must match the API's AUTH_SECRET so the API can verify minted service tokens.
AUTH_SECRET=dev-only-change-me

# Internal base URL the web server uses to reach the API (server-side + BFF proxy).
API_BASE_URL=http://localhost:3001

# Browser-visible base for the live game WebSocket gateway (/ws/*). Behind nginx
# the API is same-origin, so LEAVE THIS UNSET in production (the client derives
# wss://<host>). In local dev the API isn't proxied, so point it at the API origin:
NEXT_PUBLIC_WS_URL=ws://localhost:3001
