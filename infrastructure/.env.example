# Copy to .env (compose reads it). CHANGE ALL SECRETS for anything real.

# Postgres superuser (migration/admin role).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-superuser
POSTGRES_DB=sms

# Password for the least-privilege app role `major_user` (created on first DB init).
APP_DB_PASSWORD=change-me-app

# Shared secret: the API verifies the Auth.js JWT signed with this. Web + API must match.
AUTH_SECRET=change-me-32-char-min-secret

# Seed demo data (school + users + a class) on first backend start. Dev only.
SEED_ON_START=true

# Field-level PII encryption key (32 bytes, base64). Generate: openssl rand -base64 32
DATA_ENCRYPTION_KEY=Q5gcF3Ehy9TDmCWdhBIcu3BMCdoapo/z6xroVbv6zoE=
