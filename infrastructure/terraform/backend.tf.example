# Remote state. Copy to backend.tf AFTER bootstrapping the S3 bucket +
# DynamoDB lock table once (chicken-and-egg: create them with local state, then
# migrate). Keep state private and encrypted — it contains generated secrets.
#
#   aws s3api create-bucket --bucket sms-tfstate-<account> --region eu-west-1 \
#     --create-bucket-configuration LocationConstraint=eu-west-1
#   aws s3api put-bucket-versioning --bucket sms-tfstate-<account> \
#     --versioning-configuration Status=Enabled
#   aws dynamodb create-table --table-name sms-tflock \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH --billing-mode PAY_PER_REQUEST

terraform {
  backend "s3" {
    bucket         = "sms-tfstate-CHANGEME"
    key            = "prod/terraform.tfstate"
    region         = "eu-west-1"
    dynamodb_table = "sms-tflock"
    encrypt        = true
  }
}
