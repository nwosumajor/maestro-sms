# Copy to terraform.tfvars and fill in. NEVER commit the real file.
# Secrets here are bootstrap-only; rotate in Secrets Manager afterwards.

project         = "sms"
environment     = "prod"
region          = "eu-west-1"
azs             = ["eu-west-1a", "eu-west-1b"]

# DNS / TLS — the hosted zone must already exist in this account.
domain_name     = "app.school.example"
route53_zone_id = "Z0123456789ABCDEFGHIJ"

# CI/CD — repo allowed to assume the OIDC deploy role.
github_repo     = "your-org/sms"

# Sizing (defaults are prod-lean; bump for load).
# db_instance_class = "db.t4g.small"
# db_multi_az       = true
# api_desired_count = 2
# web_desired_count = 2

# Redis in-transit TLS + auth token (recommended for prod).
# redis_transit_encryption = true

# Fargate CPU architecture. ARM64 (Graviton, default) is ~20% cheaper; CI builds
# matching arm64 images (deploy.yml runs on an ARM runner). Flip BOTH together.
# cpu_architecture = "ARM64"

# Payment gateways. Empty = that gateway's checkout is disabled (503).
# paystack_secret_key   = "sk_live_xxx"
# stripe_secret_key     = "sk_live_xxx"
# stripe_webhook_secret = "whsec_xxx"   # set AFTER registering the webhook endpoint

# Outbound email (receipts, dunning, invites). Domain must be SPF/DKIM-verified.
# email_provider = "resend"             # or "postmark"; empty = log-only
# email_api_key  = "re_xxx"
# email_from     = "MAESTRO-SMS <no-reply@your-domain>"

# SMS / WhatsApp delivery (message credits). Empty = channels fail soft.
# sms_provider         = "twilio"
# twilio_account_sid   = "ACxxx"
# twilio_auth_token    = "xxx"
# twilio_from          = "+234xxxxxxxxxx"
# twilio_whatsapp_from = "+234xxxxxxxxxx"

# Observability. METRICS_TOKEN is auto-generated into Secrets Manager.
# sentry_dsn = "https://xxx@xxx.ingest.sentry.io/xxx"
# log_level  = "info"

# Alerting + cost guardrail. SET THIS — alarms without a subscriber are silent.
# After the first apply, CLICK the SNS confirmation emails (one per region).
# alert_email        = "ops@your-domain"
# monthly_budget_usd = 320

# Auto-scaling ceilings (floors = the desired_count values above).
# api_max_count = 10
# web_max_count = 10
